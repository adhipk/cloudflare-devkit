{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-devkit-cron-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "routes": [
    {
      "pattern": "cron.adhipk.dev",
      "custom_domain": true
    }
  ]
}
