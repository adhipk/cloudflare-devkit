{
  "name": "cloudflare-devkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cloudflare-devkit": "dist/cloudflare-devkit.js",
    "cf-devkit": "dist/cloudflare-devkit.js"
  },
  "files": [
    "dist",
    "docs",
    "recipes/*/package.json",
    "recipes/*/public/**",
    "recipes/*/src/**",
    "recipes/*/wrangler.jsonc",
    "workflow-templates",
    "README.md"
  ],
  "scripts": {
    "build:bin": "bun build bin/cloudflare-devkit.ts --target bun --outfile dist/cloudflare-devkit.js",
    "list": "bun scripts/list.ts",
    "create": "bun scripts/create.ts",
    "workflow": "bun scripts/workflow.ts",
    "deploy": "bun scripts/deploy.ts",
    "dryrun": "bun scripts/dryrun.ts",
    "smoke": "bun scripts/smoke.ts",
    "check": "bun scripts/check.ts",
    "validate": "bun scripts/validate.ts",
    "test": "bun run build:bin && bun run check && bun run validate"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
